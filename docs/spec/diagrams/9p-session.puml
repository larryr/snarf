@startuml 9p-session
title 9P session — editor core reading a host file via /mnt/host (spec 01)
skinparam shadowing false

participant "Editor core\n(9P client)" as C
participant "Mount table" as M
participant "/mnt/host server\n(device layer)" as S
participant "JS shim\n(FS Access API)" as J

== session setup (once per mount) ==
C -> S : Tversion msize=65536 "9P2000"
S --> C : Rversion msize=65536 "9P2000"
C -> S : Tattach fid=0 afid=NOFID uname="user" aname=""
S --> C : Rattach qid
C -> M : mount(fid=0, "/mnt/host")

== Get /mnt/host/src/main.zig ==
C -> M : resolve path → (server, root fid)
C -> S : Twalk fid=0 newfid=1 "src" "main.zig"
S --> C : Rwalk qid[2]
C -> S : Topen fid=1 mode=OREAD
S -> J : getFileHandle("src/main.zig")
J --> S : handle (may trigger permission prompt)
S --> C : Ropen qid iounit
loop until Rread count == 0
  C -> S : Tread fid=1 offset count
  S -> J : file.read(offset, count)
  J --> S : bytes
  S --> C : Rread data
end
C -> S : Tclunk fid=1
S --> C : Rclunk

note over S,J
  Permission denied by the user maps to
  Rerror "permission denied", never a hang.
end note
@enduml
